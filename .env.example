# ConectaCorretor B2B App - Environment Variables
PORT=3000

# Neon PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Secret (REQUIRED - use a strong random string in production)
JWT_SECRET=change_me_to_a_random_64_char_string

# S3/MinIO Storage (REQUIRED for photo uploads)
S3_URL=https://your-s3-endpoint.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=imob

# LLM API Key (OpenRouter - optional, enables AI features)
# LLM_API_KEY=sk-or-...

# CORS allowed origins (comma-separated, leave empty for dev mode)
# CORS_ORIGIN=https://yourdomain.com
